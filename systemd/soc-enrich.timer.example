# SOC Enrichment Timer
#
# Triggers soc-enrich.service every hour.
# The service drains the ambiguous event queue written by soc-agent.service
# (which runs every 2 minutes using heuristics only) and classifies events
# with Claude in a single batched call.
#
# Install:
#   sudo cp systemd/soc-enrich.timer.example /etc/systemd/system/soc-enrich.timer
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now soc-enrich.timer
#
# Check status:
#   systemctl list-timers soc-enrich.timer

[Unit]
Description=SOC Enrichment Timer - Hourly LLM classification of queued events

[Timer]
# Wait 5 minutes after boot so the agent can collect some events first
OnBootSec=5min
OnUnitActiveSec=1h

# Randomize start within 30 seconds to avoid overlapping with soc-agent runs
RandomizedDelaySec=30
AccuracySec=1s

[Install]
WantedBy=timers.target
