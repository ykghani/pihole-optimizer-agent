# PiHole Optimizer Agent Configuration

# MCP Server URL (default: http://localhost:8765)
PIHOLE_HOST=localhost
MCP_SERVER_PORT=8765 #Chosen to limit conflicts with other services running on port 80 or 8080

# Anthropic API Key (required for Claude analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email address for receiving analysis reports
EMAIL_ADDRESS=your.email@example.com

# Secret key for signing approval links in email reports.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
APPROVAL_SECRET=

# Base URL for approval links (defaults to MCP_SERVER_URL).
# If using Tailscale/VPN, set this to the externally reachable address.
# Example: http://pihole.tailnet-name.ts.net:8765
APPROVAL_BASE_URL=

# Gmail app password for the email responder (IMAP login uses EMAIL_ADDRESS above)
# Used by src/agent/email_responder.py to read replies to PiHole reports
# Generate at: https://myaccount.google.com/apppasswords (requires 2FA enabled)
GMAIL_APP_PASSWORD=your_16_char_app_password

# Logging
LOG_LEVEL=INFO

# ============================================================================
# SOC Agent Configuration
# ============================================================================

# Operating mode: shadow | recommend | auto_suppress | active
# shadow = observe only (no emails, no actions) — use for initial deployment
# recommend = observe + email alerts (no automated actions)
# auto_suppress = observe + email + auto-suppress confirmed FPs
# active = (Phase 2) auto-suppress + external IP blocking via nftables
SOC_MODE=shadow

# --- Suricata ---
SURICATA_EVE_PATH=/var/log/suricata/eve.json
SURICATA_FAST_LOG=/var/log/suricata/fast.log

# Hostname used in SOC alert email subjects and From headers
SOC_AGENT_HOSTNAME=my-pi

# --- ntopng ---
NTOPNG_URL=http://YOUR_PI_IP:3000
NTOPNG_USER=admin
NTOPNG_PASSWORD=your_ntopng_password
NTOPNG_IFACE=0

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# --- Enrichment ---
# "external" = whois + rDNS via external resolvers (default)
# "local" = no outbound queries, uses cached data only
ENRICHMENT_MODE=external
MAX_ENRICHMENT_PER_RUN=20

# --- Safety ---
# Daily Claude API cost cap (USD). Agent switches to heuristics-only if exceeded.
SOC_DAILY_API_CAP=2.0
# Block TTL in seconds. Auto-rollback after this window unless human confirms.
BLOCK_TTL_SECONDS=3600